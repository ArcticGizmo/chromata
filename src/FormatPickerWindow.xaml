<Window x:Class="Chromata.FormatPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chromata"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        SizeToContent="WidthAndHeight"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <!-- A flat, full-width row that highlights on hover. -->
        <Style x:Key="RowButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#332E8B57"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#F01B1B1F"
            BorderBrush="#33FFFFFF"
            BorderThickness="1"
            CornerRadius="10"
            Padding="6">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.55" Color="#000000"/>
        </Border.Effect>

        <StackPanel MinWidth="210">
            <!-- Header: swatch + prompt -->
            <StackPanel Orientation="Horizontal" Margin="6,4,6,8">
                <Border x:Name="Swatch" Width="22" Height="22" CornerRadius="5"
                        BorderBrush="#33FFFFFF" BorderThickness="1" Background="Black"/>
                <TextBlock Text="Copy as…" Margin="10,0,0,0" VerticalAlignment="Center"
                           Foreground="#C8C8CC" FontSize="12" FontWeight="SemiBold"/>
            </StackPanel>

            <!-- One clickable row per format -->
            <ItemsControl x:Name="Rows">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Style="{StaticResource RowButton}" Tag="{Binding Value}" Click="Row_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="42"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Label}"
                                           Foreground="#8A8A90" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding Value}"
                                           Foreground="White" FontFamily="Consolas, Cascadia Mono"
                                           FontSize="13" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="Esc to cancel" Foreground="#80FFFFFF" FontSize="10"
                       HorizontalAlignment="Center" Margin="0,6,0,2"/>
        </StackPanel>
    </Border>
</Window>
