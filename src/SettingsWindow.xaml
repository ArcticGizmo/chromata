<Window x:Class="Chromata.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chromata Settings"
        Width="380" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#1B1B1F"
        UseLayoutRounding="True">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E8E8EA"/>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="#E8E8EA"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="18">
        <!-- Shortcut -->
        <TextBlock Text="Global shortcut" FontWeight="SemiBold" FontSize="13"/>
        <TextBox x:Name="HotkeyBox" IsReadOnly="True" Margin="0,6,0,0"
                 Padding="8,6" FontFamily="Consolas, Cascadia Mono" FontSize="14"
                 Background="#2A2A30" Foreground="White" BorderBrush="#444"
                 Cursor="Hand" PreviewKeyDown="HotkeyBox_PreviewKeyDown"/>
        <TextBlock Text="Click the box, then press a combination (include Ctrl or Alt)."
                   Foreground="#9A9AA0" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>

        <!-- Copy format -->
        <TextBlock Text="Copy format" FontWeight="SemiBold" FontSize="13" Margin="0,18,0,0"/>
        <RadioButton x:Name="RbHexUpper" GroupName="fmt" Checked="Format_Checked" Tag="HexUpper"
                     Content="HEX uppercase   #2E8B57"/>
        <RadioButton x:Name="RbHexLower" GroupName="fmt" Checked="Format_Checked" Tag="HexLower"
                     Content="hex lowercase   #2e8b57"/>
        <RadioButton x:Name="RbRgb" GroupName="fmt" Checked="Format_Checked" Tag="Rgb"
                     Content="rgb()   rgb(46, 139, 87)"/>
        <RadioButton x:Name="RbHsl" GroupName="fmt" Checked="Format_Checked" Tag="Hsl"
                     Content="hsl()   hsl(146, 50%, 36%)"/>

        <!-- Recent colours -->
        <Grid Margin="0,18,0,0">
            <TextBlock Text="Recent colours" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
            <Button x:Name="ClearButton" Content="Clear" HorizontalAlignment="Right"
                    Padding="10,3" Click="Clear_Click"/>
        </Grid>
        <Border Margin="0,6,0,0" BorderBrush="#333" BorderThickness="1" CornerRadius="4">
            <ListBox x:Name="HistoryList" Height="150" Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
        </Border>

        <Button Content="Close" HorizontalAlignment="Right" Margin="0,16,0,0"
                Padding="16,5" Click="Close_Click"/>
    </StackPanel>
</Window>
