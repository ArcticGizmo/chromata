<Window x:Class="Chromata.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chromata"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        SizeToContent="WidthAndHeight"
        IsHitTestVisible="False"
        UseLayoutRounding="True">
    <Border Background="#F01B1B1F"
            BorderBrush="#33FFFFFF"
            BorderThickness="1"
            CornerRadius="10"
            Padding="14,10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.55" Color="#000000"/>
        </Border.Effect>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <Border x:Name="Swatch" Width="22" Height="22" CornerRadius="5"
                    BorderBrush="#33FFFFFF" BorderThickness="1" Background="Black"/>
            <TextBlock x:Name="Label" Margin="10,0,2,0" VerticalAlignment="Center"
                       Foreground="White" FontFamily="Consolas, Cascadia Mono"
                       FontSize="14" FontWeight="SemiBold" Text="#000000 copied"/>
        </StackPanel>
    </Border>
</Window>
