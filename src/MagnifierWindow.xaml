<Window x:Class="Chromata.MagnifierWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chromata"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        SizeToContent="WidthAndHeight"
        IsHitTestVisible="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Border Background="#F01B1B1F"
            BorderBrush="#33FFFFFF"
            BorderThickness="1"
            CornerRadius="10"
            Padding="6">
        <Border.Effect>
            <DropShadowEffect BlurRadius="14" ShadowDepth="0" Opacity="0.5" Color="#000000"/>
        </Border.Effect>

        <StackPanel>
            <!-- Zoomed pixels with a crosshair on the sampled pixel -->
            <Border CornerRadius="6" ClipToBounds="True"
                    BorderBrush="#22FFFFFF" BorderThickness="1">
                <Grid Width="180" Height="180">
                    <Image x:Name="LoupeImage"
                           Stretch="Fill"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                           RenderOptions.EdgeMode="Aliased"/>
                    <Canvas x:Name="Overlay">
                        <Rectangle x:Name="CrosshairCell"
                                   Stroke="White" StrokeThickness="1.5"
                                   Width="0" Height="0"/>
                        <Rectangle x:Name="CrosshairCellInner"
                                   Stroke="Black" StrokeThickness="1"
                                   Width="0" Height="0"/>
                    </Canvas>
                </Grid>
            </Border>

            <!-- Swatch + readouts -->
            <Grid Margin="2,8,2,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="Swatch" Grid.Column="0"
                        Width="34" Height="34" CornerRadius="6"
                        BorderBrush="#33FFFFFF" BorderThickness="1"
                        Background="Black"/>

                <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="HexText" Text="#000000"
                               Foreground="White" FontFamily="Consolas, Cascadia Mono"
                               FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock x:Name="RgbText" Text="rgb(0, 0, 0)"
                               Foreground="#B0FFFFFF" FontFamily="Consolas, Cascadia Mono"
                               FontSize="11"/>
                </StackPanel>
            </Grid>

            <TextBlock Text="Click to copy · Esc to cancel"
                       Foreground="#80FFFFFF" FontSize="10"
                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
        </StackPanel>
    </Border>
</Window>
